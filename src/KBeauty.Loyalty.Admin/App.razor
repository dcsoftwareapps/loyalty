@*
  Componente raíz: emite el HTML del documento. Se renderiza una sola vez por
  request (Static SSR); a partir de ahí Routes.razor monta la app interactiva.

  La importación de fuentes Cormorant Garamond + DM Sans está aquí — son
  parte del sistema de diseño y nunca deben cambiar por página.
*@
<!DOCTYPE html>
<html lang="es-MX">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#F7F5F0" />
    <base href="/" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@400;500;700&display=swap" />

    <link rel="stylesheet" href="css/site.css" />

    <title>KBeauty Loyalty</title>
    <HeadOutlet />
</head>
<body>
    <Routes />
    <script src="js/jsQR.js"></script>
    <script src="js/qr-scanner.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
