@page "/config"
@attribute [Authorize]
@rendermode InteractiveServer

@using KBeauty.Loyalty.Application.Config.Commands.UpdateProgramConfig
@using KBeauty.Loyalty.Application.Config.Queries.GetProgramConfig
@inject ISender Sender

<PageTitle>Configuración · KBeauty</PageTitle>

<h1>Configuración del programa</h1>
<p style="color: var(--kb-ink-muted); max-width: 600px;">
    Toda la lógica del programa lee de aquí. Los cambios aplican de inmediato a las
    siguientes operaciones (no se aplican retroactivamente al historial).
</p>

@if (entries is null)
{
    <p>Cargando…</p>
}
else
{
    @if (successMsg is not null) { <div class="kb-form-success">@successMsg</div> }
    @if (errorMsg is not null) { <div class="kb-form-error">@errorMsg</div> }

    <table class="kb-table" style="max-width: 800px;">
        <thead>
            <tr>
                <th>Regla</th>
                <th>Valor</th>
                <th>Última actualización</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var e in entries)
        {
            <tr>
                <td>
                    <strong>@FriendlyName(e.Key)</strong>
                    <br/><code style="color:var(--kb-ink-muted);font-size:0.8rem;">@e.Key</code>
                </td>
                <td>
                    <input type="text" @bind="edited[e.Key]" style="max-width: 160px;" />
                </td>
                <td style="color: var(--kb-ink-muted);">
                    @e.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    @if (!string.IsNullOrEmpty(e.UpdatedBy))
                    {
                        <br/><small>por @e.UpdatedBy</small>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>

    <button class="kb-btn kb-btn--primary kb-btn--large" style="margin-top: 24px;"
            @onclick="SaveAsync" disabled="@busy">
        @(busy ? "Guardando…" : "Guardar cambios")
    </button>
}

@code {
    private List<ConfigDto>? entries;
    private Dictionary<string, string> edited = new();
    private string? successMsg;
    private string? errorMsg;
    private bool busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var result = await Sender.Send(new GetProgramConfigQuery());
        if (result.IsSuccess)
        {
            entries = result.Value.ToList();
            edited = entries.ToDictionary(e => e.Key, e => e.Value);
        }
    }

    private async Task SaveAsync()
    {
        successMsg = errorMsg = null;
        busy = true;

        // Solo enviar las claves que cambiaron.
        var changed = entries!
            .Where(e => edited[e.Key] != e.Value)
            .Select(e => new ConfigEntry(e.Key, edited[e.Key]))
            .ToList();

        if (changed.Count == 0)
        {
            successMsg = "Sin cambios para guardar.";
            busy = false;
            return;
        }

        var result = await Sender.Send(new UpdateProgramConfigCommand(changed, "admin-panel"));
        busy = false;

        if (result.IsSuccess)
        {
            successMsg = $"Guardadas {changed.Count} regla(s).";
            await LoadAsync();
        }
        else
        {
            errorMsg = result.Error;
        }
    }

    // Mapping legible para mostrar en la tabla — no afecta los keys reales.
    private static string FriendlyName(string key) => key switch
    {
        "points_per_peso_unit" => "Pesos por 1 punto",
        "welcome_bonus_points" => "Puntos de bienvenida",
        "referral_bonus_points" => "Puntos por referido",
        "birthday_multiplier" => "Multiplicador cumpleaños",
        "level_mist_min" => "Umbral Mist",
        "level_glow_min" => "Umbral Glow",
        "level_radiance_min" => "Umbral Radiance",
        "radiance_requalification_points" => "Re-cualificación Radiance (pts/año)",
        var k when k.StartsWith("reward_") => "Costo de canje: " + k.Replace("reward_", "").Replace("_points", "").Replace("_", " "),
        _ => key
    };
}
