@page "/join"
@layout EmptyLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer

@using System.Net.Http.Json
@using Microsoft.AspNetCore.Mvc
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Unete a KBeauty Loyalty</PageTitle>

<main class="kb-join">
    <section class="kb-join-card">
        <div class="kb-join-brand">KBeauty Loyalty</div>
        <h1>Unete a nuestro programa de lealtad</h1>
        <p class="kb-muted">Agrega tu tarjeta a Apple Wallet y acumula puntos en cada compra.</p>

        @if (errorMsg is not null)
        {
            <div class="kb-form-error">@errorMsg</div>
        }

        @if (joinResult is null)
        {
            <div class="kb-form-row">
                <div>
                    <label for="first-name">Nombre</label>
                    <input id="first-name" type="text" autocomplete="given-name" @bind="form.FirstName" />
                </div>
                <div>
                    <label for="last-name">Apellido</label>
                    <input id="last-name" type="text" autocomplete="family-name" @bind="form.LastName" />
                </div>
                <div>
                    <label for="phone">Telefono</label>
                    <input id="phone" type="tel" inputmode="tel" autocomplete="tel" @bind="form.Phone" />
                </div>
                <button class="kb-btn kb-btn--primary kb-btn--block kb-btn--large" @onclick="JoinAsync" disabled="@busy">
                    @(busy ? "Preparando..." : "Agregar a Apple Wallet")
                </button>
            </div>
        }
        else
        {
            <div class="kb-form-success">@joinResult.Message</div>
            <h2>Tu tarjeta de KBeauty Loyalty esta lista.</h2>
            <a class="kb-btn kb-btn--primary kb-btn--block kb-btn--large" href="@joinResult.PassDownloadUrl">
                Agregar a Apple Wallet
            </a>

            @if (!birthdaySaved && !birthdaySkipped)
            {
                <div class="kb-join-birthday">
                    <h2>Agrega tu cumpleanos</h2>
                    <p class="kb-muted">Recibe beneficios especiales en tu mes.</p>
                    <div class="kb-form-row kb-form-row--horizontal">
                        <div style="flex:1;min-width:120px;">
                            <label for="birthday-day">Dia</label>
                            <select id="birthday-day" @bind="birthday.Day">
                                @for (var day = 1; day <= 31; day++)
                                {
                                    <option value="@day">@day</option>
                                }
                            </select>
                        </div>
                        <div style="flex:1;min-width:140px;">
                            <label for="birthday-month">Mes</label>
                            <select id="birthday-month" @bind="birthday.Month">
                                @for (var month = 1; month <= 12; month++)
                                {
                                    <option value="@month">@MonthName(month)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="kb-actions-inline" style="width:100%;">
                        <button class="kb-btn kb-btn--primary" @onclick="SaveBirthdayAsync" disabled="@busy">
                            Guardar cumpleanos
                        </button>
                        <button class="kb-btn kb-btn--ghost" @onclick="@(() => birthdaySkipped = true)" disabled="@busy">
                            Omitir por ahora
                        </button>
                    </div>
                </div>
            }
            else if (birthdaySaved)
            {
                <div class="kb-form-success">Cumpleanos guardado.</div>
            }
        }
    </section>
</main>

@code {
    private readonly JoinForm form = new();
    private readonly BirthdayForm birthday = new();
    private PublicJoinResponse? joinResult;
    private string? errorMsg;
    private bool busy;
    private bool birthdaySaved;
    private bool birthdaySkipped;

    private HttpClient Api => HttpClientFactory.CreateClient("KBeautyApi");

    private async Task JoinAsync()
    {
        errorMsg = null;
        if (string.IsNullOrWhiteSpace(form.FirstName)
            || string.IsNullOrWhiteSpace(form.LastName)
            || string.IsNullOrWhiteSpace(form.Phone))
        {
            errorMsg = "Captura nombre, apellido y telefono.";
            return;
        }

        busy = true;
        try
        {
            using var response = await Api.PostAsJsonAsync("api/public/join", new PublicJoinRequest(
                form.FirstName.Trim(),
                form.LastName.Trim(),
                form.Phone.Trim()));

            if (!response.IsSuccessStatusCode)
            {
                errorMsg = await ReadApiErrorAsync(response);
                return;
            }

            joinResult = await response.Content.ReadFromJsonAsync<PublicJoinResponse>();
            if (joinResult is null)
                errorMsg = "No pudimos preparar tu tarjeta. Intenta de nuevo.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task SaveBirthdayAsync()
    {
        if (joinResult is null)
            return;

        errorMsg = null;
        if (birthday.Day < 1 || birthday.Month < 1 || birthday.Month > 12 || birthday.Day > DateTime.DaysInMonth(2000, birthday.Month))
        {
            errorMsg = "El dia no es valido para el mes seleccionado.";
            return;
        }

        busy = true;
        try
        {
            using var response = await Api.PutAsJsonAsync(
                $"api/public/join/{joinResult.SerialNumber}/birthday",
                new PublicBirthdayRequest(birthday.Day, birthday.Month));

            if (!response.IsSuccessStatusCode)
            {
                errorMsg = await ReadApiErrorAsync(response);
                return;
            }

            birthdaySaved = true;
        }
        finally
        {
            busy = false;
        }
    }

    private static async Task<string> ReadApiErrorAsync(HttpResponseMessage response)
    {
        try
        {
            var problem = await response.Content.ReadFromJsonAsync<ProblemDetails>();
            if (!string.IsNullOrWhiteSpace(problem?.Detail))
                return problem.Detail;
            if (!string.IsNullOrWhiteSpace(problem?.Title))
                return problem.Title;
        }
        catch
        {
            // Fall through to raw content.
        }

        var content = await response.Content.ReadAsStringAsync();
        return string.IsNullOrWhiteSpace(content)
            ? "Ocurrio un problema. Intenta de nuevo."
            : content;
    }

    private static string MonthName(int month) => month switch
    {
        1 => "Enero",
        2 => "Febrero",
        3 => "Marzo",
        4 => "Abril",
        5 => "Mayo",
        6 => "Junio",
        7 => "Julio",
        8 => "Agosto",
        9 => "Septiembre",
        10 => "Octubre",
        11 => "Noviembre",
        12 => "Diciembre",
        _ => month.ToString()
    };

    private sealed class JoinForm
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
    }

    private sealed class BirthdayForm
    {
        public int Day { get; set; } = 1;
        public int Month { get; set; } = 1;
    }

    private sealed record PublicJoinRequest(string FirstName, string LastName, string Phone);

    private sealed record PublicJoinResponse(
        Guid CustomerId,
        string SerialNumber,
        string FullName,
        string Phone,
        bool AlreadyExists,
        string Message,
        string PassDownloadUrl);

    private sealed record PublicBirthdayRequest(int Day, int Month);
}
