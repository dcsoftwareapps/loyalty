@page "/redemptions"
@attribute [Authorize]
@rendermode InteractiveServer

@using KBeauty.Loyalty.Application.Redemptions.Commands.CancelRedemption
@using KBeauty.Loyalty.Application.Redemptions.Commands.ConfirmRedemption
@using KBeauty.Loyalty.Application.Redemptions.Queries.ListRedemptions
@using KBeauty.Loyalty.Domain.Enums
@inject ISender Sender

<PageTitle>Canjes - KBeauty</PageTitle>

<h1>Canjes</h1>

@if (successMsg is not null) { <div class="kb-form-success">@successMsg</div> }
@if (errorMsg is not null) { <div class="kb-form-error">@errorMsg</div> }

<div class="kb-form-row kb-form-row--horizontal" style="margin-bottom:24px;">
    <button class="@FilterButtonClass(null)" @onclick="@(() => SetStatusFilter(null))">Todos</button>
    <button class="@FilterButtonClass(RedemptionStatus.Pending)" @onclick="@(() => SetStatusFilter(RedemptionStatus.Pending))">Pendientes</button>
    <button class="@FilterButtonClass(RedemptionStatus.Confirmed)" @onclick="@(() => SetStatusFilter(RedemptionStatus.Confirmed))">Confirmados</button>
    <button class="@FilterButtonClass(RedemptionStatus.Cancelled)" @onclick="@(() => SetStatusFilter(RedemptionStatus.Cancelled))">Cancelados</button>
</div>

@if (redemptions is null)
{
    <p>Cargando...</p>
}
else if (redemptions.Count == 0)
{
    <p style="color: var(--kb-ink-muted);">No hay canjes para este filtro.</p>
}
else
{
    <table class="kb-table">
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Serial</th>
                <th>Recompensa</th>
                <th>Puntos</th>
                <th>Estado</th>
                <th>Fecha de solicitud</th>
                <th>Fecha de resolucion</th>
                <th>Operador</th>
                <th>Notas</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in redemptions)
        {
            <tr>
                <td>@item.CustomerName</td>
                <td><code>@item.SerialNumber</code></td>
                <td>@item.RewardName</td>
                <td style="color: var(--kb-blush); font-weight: 600;">@item.PointsSpent.ToString("N0")</td>
                <td>@StatusText(item.Status)</td>
                <td style="color: var(--kb-ink-muted);">@item.RedeemedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                <td style="color: var(--kb-ink-muted);">@FormatDate(item.ResolvedAt)</td>
                <td style="color: var(--kb-ink-muted);">@DisplayText(item.ResolvedBy)</td>
                <td style="color: var(--kb-ink-muted); max-width:220px;">@DisplayText(item.Notes)</td>
                <td>
                    @if (item.Status == RedemptionStatus.Pending)
                    {
                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            <button class="kb-btn kb-btn--primary" @onclick="@(() => Confirm(item.RedemptionId))">
                                Confirmar
                            </button>
                            <button class="kb-btn kb-btn--ghost" @onclick="@(() => Cancel(item.RedemptionId))">
                                Cancelar
                            </button>
                        </div>
                    }
                    else
                    {
                        <span style="color: var(--kb-ink-muted);">@StatusText(item.Status)</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<ConfirmModal Show="@showConfirmModal"
              Title="Confirmar entrega"
              Message="Confirmas que entregaste el beneficio a la clienta?"
              ConfirmText="Si, entregado"
              OnConfirm="DoConfirmAsync"
              OnCancel="CloseConfirmModal" />

@if (showCancelModal)
{
    <div class="kb-modal-overlay" @onclick="CloseCancelModal">
        <div class="kb-modal" @onclick:stopPropagation>
            <h3>Cancelar canje</h3>
            <p>Al cancelar, los puntos se restauran a la clienta y Wallet se actualiza.</p>
            <label for="cancel-notes">Nota opcional</label>
            <textarea id="cancel-notes" rows="3" @bind="cancelNotes"></textarea>
            <div class="kb-modal-actions">
                <button class="kb-btn kb-btn--ghost" @onclick="CloseCancelModal">Volver</button>
                <button class="kb-btn kb-btn--primary" @onclick="DoCancelAsync">Cancelar canje</button>
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<RedemptionHistoryItemDto>? redemptions;
    private RedemptionStatus? statusFilter = RedemptionStatus.Pending;
    private bool showConfirmModal;
    private bool showCancelModal;
    private Guid? confirmTargetId;
    private Guid? cancelTargetId;
    private string? cancelNotes;
    private string? successMsg;
    private string? errorMsg;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        var result = await Sender.Send(new ListRedemptionsQuery(statusFilter));
        if (result.IsSuccess)
        {
            redemptions = result.Value;
            return;
        }

        errorMsg = result.Error;
        redemptions = Array.Empty<RedemptionHistoryItemDto>();
    }

    private async Task SetStatusFilter(RedemptionStatus? status)
    {
        statusFilter = status;
        ClearMessages();
        await ReloadAsync();
    }

    private void Confirm(Guid id)
    {
        ClearMessages();
        confirmTargetId = id;
        showConfirmModal = true;
    }

    private async Task DoConfirmAsync()
    {
        if (confirmTargetId is null) return;

        var result = await Sender.Send(new ConfirmRedemptionCommand(confirmTargetId.Value, "admin-panel"));
        CloseConfirmModal();

        if (result.IsFailure)
        {
            errorMsg = result.Error;
            return;
        }

        successMsg = "Canje confirmado.";
        await ReloadAsync();
    }

    private void Cancel(Guid id)
    {
        ClearMessages();
        cancelTargetId = id;
        cancelNotes = null;
        showCancelModal = true;
    }

    private async Task DoCancelAsync()
    {
        if (cancelTargetId is null) return;

        var result = await Sender.Send(new CancelRedemptionCommand(
            cancelTargetId.Value,
            "admin-panel",
            string.IsNullOrWhiteSpace(cancelNotes) ? null : cancelNotes.Trim()));

        CloseCancelModal();

        if (result.IsFailure)
        {
            errorMsg = result.Error;
            return;
        }

        successMsg = $"Canje cancelado. Se restauraron {result.Value.PointsRestored:N0} pts.";
        await ReloadAsync();
    }

    private void CloseConfirmModal()
    {
        showConfirmModal = false;
        confirmTargetId = null;
    }

    private void CloseCancelModal()
    {
        showCancelModal = false;
        cancelTargetId = null;
        cancelNotes = null;
    }

    private void ClearMessages()
    {
        successMsg = null;
        errorMsg = null;
    }

    private string FilterButtonClass(RedemptionStatus? status) =>
        statusFilter == status ? "kb-btn kb-btn--primary" : "kb-btn kb-btn--ghost";

    private static string StatusText(RedemptionStatus status) => status switch
    {
        RedemptionStatus.Pending => "Pendiente",
        RedemptionStatus.Confirmed => "Confirmado",
        RedemptionStatus.Cancelled => "Cancelado",
        _ => status.ToString()
    };

    private static string FormatDate(DateTime? value) =>
        value.HasValue ? value.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm") : "-";

    private static string DisplayText(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;
}
