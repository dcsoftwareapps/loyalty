@page "/customers/{CustomerId:guid}"
@page "/customers/{SerialNumber}"
@attribute [Authorize]
@rendermode InteractiveServer

@using KBeauty.Loyalty.Application.Customers.Queries.GetCustomerDetail
@using KBeauty.Loyalty.Application.Customers.Commands.UpdateCustomerBirthday
@using KBeauty.Loyalty.Domain.Enums
@inject ISender Sender
@inject NavigationManager Nav

<PageTitle>@(detail?.Summary.FullName ?? "Clienta") - KBeauty</PageTitle>

@if (errorMsg is not null)
{
    <div class="kb-form-error">@errorMsg</div>
    <a href="/customers" class="kb-btn kb-btn--ghost">Volver</a>
}
else if (detail is null)
{
    <p>Cargando...</p>
}
else
{
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:24px;">
        <div>
            <a href="/customers" style="color: var(--kb-ink-muted);">Volver a clientas</a>
            <h1 style="margin-top:12px;">@detail.Summary.FullName</h1>
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                <LevelBadge Level="@detail.Summary.Level" />
                <span class="@StatusBadgeClass(detail.Summary.IsActive)">@(detail.Summary.IsActive ? "Activo" : "Inactivo")</span>
                <span class="@StatusBadgeClass(detail.Summary.WalletIssued)">Wallet @(detail.Summary.WalletIssued ? "emitida" : "no emitida")</span>
            </div>
            <p class="kb-muted" style="margin-top:12px;">
                @detail.Summary.Email
                @if (!string.IsNullOrWhiteSpace(detail.Summary.Phone))
                {
                    <span> · @detail.Summary.Phone</span>
                }
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(detail.Wallet.SerialNumber))
        {
            <button class="kb-btn kb-btn--primary" @onclick="@(() => Nav.NavigateTo($"/scan?serial={detail.Wallet.SerialNumber}"))">
                Sumar puntos
            </button>
        }
    </div>

    <section style="margin-bottom:32px;">
        <h2>Estadísticas rápidas</h2>
        <div class="kb-grid">
            <MetricCard Label="Puntos actuales" Value="@FormatNumber(detail.Statistics.CurrentPoints)" />
            <MetricCard Label="Puntos rolling" Value="@FormatNumber(detail.Statistics.RollingPoints)" />
            <MetricCard Label="Puntos históricos" Value="@FormatNumber(detail.Statistics.LifetimePoints)" />
            <MetricCard Label="Puntos canjeados" Value="@FormatNumber(detail.Statistics.PointsRedeemed)" />
            <MetricCard Label="Total de canjes" Value="@FormatNumber(detail.Statistics.TotalRedemptions)" />
            <MetricCard Label="Pendientes" Value="@FormatNumber(detail.Statistics.PendingRedemptions)" />
            <MetricCard Label="Cancelados" Value="@FormatNumber(detail.Statistics.CancelledRedemptions)" />
            <MetricCard Label="Confirmados" Value="@FormatNumber(detail.Statistics.ConfirmedRedemptions)" />
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Información general</h2>
        <div class="kb-card">
            <div class="kb-detail-grid">
                <DetailItem Label="Nombre completo" Value="@detail.Summary.FullName" />
                <DetailItem Label="Email" Value="@detail.Summary.Email" />
                <DetailItem Label="Teléfono" Value="@DisplayText(detail.Summary.Phone)" />
                <DetailItem Label="Cumpleaños" Value="@BirthdayText()" />
                <DetailItem Label="Fecha de registro" Value="@FormatDate(detail.Summary.CreatedAt)" />
                <DetailItem Label="Estado" Value="@StatusText(detail.Summary.IsActive)" />
                <DetailItem Label="Nivel actual" Value="@detail.Summary.Level" />
                <DetailItem Label="Fecha de nivel" Value="@FormatNullableDateTime(detail.Summary.LevelAchievedAt)" />
                <DetailItem Label="Wallet emitida" Value="@YesNo(detail.Summary.WalletIssued)" />
            </div>
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Cumpleaños</h2>
        <div class="kb-card">
            @if (birthdaySuccess is not null)
            {
                <div class="kb-form-success">@birthdaySuccess</div>
            }
            @if (birthdayError is not null)
            {
                <div class="kb-form-error">@birthdayError</div>
            }
            <div class="kb-form-row kb-form-row--horizontal">
                <div style="flex:1;min-width:120px;">
                    <label for="birthday-day">Día</label>
                    <select id="birthday-day" @bind="birthdayDay">
                        @for (var day = 1; day <= 31; day++)
                        {
                            <option value="@day">@day</option>
                        }
                    </select>
                </div>
                <div style="flex:1;min-width:140px;">
                    <label for="birthday-month">Mes</label>
                    <select id="birthday-month" @bind="birthdayMonth">
                        @for (var month = 1; month <= 12; month++)
                        {
                            <option value="@month">@MonthName(month)</option>
                        }
                    </select>
                </div>
                <button class="kb-btn kb-btn--primary" @onclick="SaveBirthdayAsync" disabled="@birthdayBusy">
                    Guardar cumpleaños
                </button>
            </div>
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Auditoría de saldo</h2>
        <div class="kb-grid">
            <MetricCard Label="Saldo disponible" Value="@FormatNumber(detail.Statistics.CurrentPoints)" />
            <MetricCard Label="Rolling 12 meses" Value="@FormatNumber(detail.LoyaltyAudit.RollingProgress.RollingPoints)" />
            <MetricCard Label="Lifetime Points" Value="@FormatNumber(detail.Statistics.LifetimePoints)" />
            <MetricCard Label="Nivel actual" Value="@detail.LoyaltyAudit.RollingProgress.CurrentLevel" />
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Próxima expiración</h2>
        <div class="kb-card">
            @if (detail.LoyaltyAudit.UpcomingExpiration is null)
            {
                <p class="kb-muted" style="margin:0;">Sin puntos próximos a expirar.</p>
            }
            else
            {
                <div class="kb-detail-grid">
                    <DetailItem Label="Fecha" Value="@FormatDate(detail.LoyaltyAudit.UpcomingExpiration.ExpiresAt)" />
                    <DetailItem Label="Puntos" Value="@($"{FormatNumber(detail.LoyaltyAudit.UpcomingExpiration.Points)} puntos")" />
                </div>
            }
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Rolling Progress</h2>
        <div class="kb-card">
            <div class="kb-detail-grid">
                <DetailItem Label="Rolling Points" Value="@FormatNumber(detail.LoyaltyAudit.RollingProgress.RollingPoints)" />
                <DetailItem Label="Glow" Value="@ThresholdText(detail.LoyaltyAudit.RollingProgress.GlowThreshold, detail.LoyaltyAudit.RollingProgress.RollingPoints)" />
                <DetailItem Label="Radiance" Value="@ThresholdText(detail.LoyaltyAudit.RollingProgress.RadianceThreshold, detail.LoyaltyAudit.RollingProgress.RollingPoints)" />
                <DetailItem Label="Siguiente nivel" Value="@detail.LoyaltyAudit.RollingProgress.NextLevel" />
                <DetailItem Label="Faltan" Value="@($"{FormatNumber(detail.LoyaltyAudit.RollingProgress.PointsToNextLevel)} puntos")" />
            </div>
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Tarjeta Loyalty / Wallet</h2>
        @if (!detail.Wallet.WalletIssued)
        {
            <p class="kb-muted">Este cliente aun no tiene Wallet emitida.</p>
        }
        else
        {
            <div class="kb-card">
                <div class="kb-detail-grid">
                    <DetailItem Label="Número de tarjeta" Value="@DisplayText(detail.Wallet.SerialNumber)" />
                    <DetailItem Label="Puntos actuales" Value="@FormatNullableNumber(detail.Wallet.CurrentPoints)" />
                    <DetailItem Label="Fecha de emisión" Value="@FormatNullableDate(detail.Wallet.IssuedAt)" />
                    <DetailItem Label="Última actualización" Value="@FormatNullableDateTime(detail.Wallet.LastActivityAt)" />
                    <DetailItem Label="Dispositivos registrados" Value="@FormatNumber(detail.Wallet.DeviceRegistrationCount)" />
                    <DetailItem Label="Último push enviado" Value="@FormatNullableDateTime(detail.Wallet.LastPushSentAt)" />
                </div>
            </div>
        }
    </section>

    <section style="margin-bottom:32px;">
        <h2>Notificaciones</h2>
        @if (detail.NotificationHistory.Count == 0)
        {
            <p class="kb-muted">Sin notificaciones registradas.</p>
        }
        else
        {
            <table class="kb-table kb-table--compact">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Mensaje</th>
                        <th>Estado</th>
                        <th>Apple Wallet</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in detail.NotificationHistory)
                {
                    <tr>
                        <td class="kb-muted">@FormatDateTime(item.CreatedAt)</td>
                        <td><span class="kb-badge kb-badge--muted">@item.Type</span></td>
                        <td>
                            <strong>@item.Title</strong>
                            <div class="kb-muted kb-text-truncate" title="@item.Message">@item.Message</div>
                        </td>
                        <td><span class="@NotificationStatusBadgeClass(item.Status)">@item.Status</span></td>
                        <td class="kb-muted">@($"{item.PushesAccepted}/{item.PushesAttempted} aceptados")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section style="margin-bottom:32px;">
        <h2>Historial de puntos</h2>
        @if (detail.PointHistory.Count == 0)
        {
            <p class="kb-muted">Sin movimientos de puntos.</p>
        }
        else
        {
            <table class="kb-table kb-table--compact">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Descripción</th>
                        <th>Campaña</th>
                        <th class="kb-cell-number">Puntos</th>
                        <th>Balance después</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in detail.PointHistory)
                {
                    <tr>
                        <td class="kb-muted">@FormatDateTime(item.CreatedAt)</td>
                        <td><span class="kb-badge kb-badge--muted">@item.Type</span></td>
                        <td>@item.Description</td>
                        <td>@CampaignText(item.CampaignName, item.AppliedMultiplier)</td>
                        <td class="kb-cell-number" style="font-weight:600;color:@PointColor(item.Points);">
                            @(item.Points > 0 ? "+" : "")@item.Points.ToString("N0")
                        </td>
                        <td class="kb-muted">@FormatNullableNumber(item.BalanceAfter)</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section style="margin-bottom:32px;">
        <h2>Lotes de puntos</h2>
        @if (detail.LoyaltyAudit.Lots.Count == 0)
        {
            <p class="kb-muted">Sin lotes de puntos.</p>
        }
        else
        {
            <table class="kb-table kb-table--compact">
                <thead>
                    <tr>
                        <th>Ganado</th>
                        <th>Expira</th>
                        <th class="kb-cell-number">Original</th>
                        <th class="kb-cell-number">Disponible</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var lot in detail.LoyaltyAudit.Lots)
                {
                    <tr>
                        <td class="kb-muted">@FormatDate(lot.EarnedAt)</td>
                        <td class="kb-muted">@FormatDate(lot.ExpiresAt)</td>
                        <td class="kb-cell-number">@FormatNumber(lot.OriginalAmount)</td>
                        <td class="kb-cell-number">@FormatNumber(lot.RemainingAmount)</td>
                        <td><span class="@LotStatusBadgeClass(lot.Status)">@lot.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section style="margin-bottom:32px;">
        <h2>Consumo FIFO</h2>
        @if (detail.LoyaltyAudit.Consumptions.Count == 0)
        {
            <p class="kb-muted">Sin consumos FIFO registrados.</p>
        }
        else
        {
            <table class="kb-table kb-table--compact">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Lote</th>
                        <th>Motivo</th>
                        <th>Reward</th>
                        <th class="kb-cell-number">Consumido</th>
                        <th class="kb-cell-number">Quedo</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in detail.LoyaltyAudit.Consumptions)
                {
                    <tr>
                        <td class="kb-muted">@FormatDateTime(item.ConsumedAt)</td>
                        <td class="kb-muted">@FormatDate(item.LotExpiresAt)</td>
                        <td><span class="kb-badge kb-badge--muted">@item.Reason</span></td>
                        <td>@DisplayText(item.RewardName)</td>
                        <td class="kb-cell-number">@FormatNumber(item.AmountConsumed)</td>
                        <td class="kb-cell-number">@FormatNumber(item.RemainingAfterConsumption)</td>
                        <td>@(item.IsReversed ? "Revertido" : "Aplicado")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>

    <section>
        <h2>Historial de canjes</h2>
        @if (detail.RedemptionHistory.Count == 0)
        {
            <p class="kb-muted">Sin canjes registrados.</p>
        }
        else
        {
            <table class="kb-table kb-table--compact">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Reward</th>
                        <th>Estado</th>
                        <th class="kb-cell-number">Puntos utilizados</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in detail.RedemptionHistory)
                {
                    <tr>
                        <td class="kb-muted">@FormatDateTime(item.RedeemedAt)</td>
                        <td>@item.RewardName</td>
                        <td><span class="@RedemptionStatusBadgeClass(item.Status)">@item.Status</span></td>
                        <td class="kb-cell-number" style="font-weight:600;">@item.PointsSpent.ToString("N0")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
}

@code {
    [Parameter] public Guid CustomerId { get; set; }
    [Parameter] public string? SerialNumber { get; set; }

    private CustomerDetailDto? detail;
    private string? errorMsg;
    private string? birthdaySuccess;
    private string? birthdayError;
    private bool birthdayBusy;
    private int birthdayDay = 1;
    private int birthdayMonth = 1;

    protected override async Task OnInitializedAsync()
    {
        if (CustomerId == Guid.Empty && !string.IsNullOrWhiteSpace(SerialNumber))
        {
            var legacyResult = await Sender.Send(
                new KBeauty.Loyalty.Application.Customers.Queries.GetCustomerBySerial.GetCustomerBySerialQuery(SerialNumber));
            if (legacyResult.IsSuccess)
            {
                Nav.NavigateTo($"/customers/{legacyResult.Value.CustomerId}", replace: true);
                return;
            }

            errorMsg = legacyResult.Error;
            return;
        }

        var result = await Sender.Send(new GetCustomerDetailQuery(CustomerId));
        if (result.IsSuccess)
        {
            detail = result.Value;
            birthdayDay = detail.Summary.BirthdayCaptured ? detail.Summary.DateOfBirth.Day : 1;
            birthdayMonth = detail.Summary.BirthdayCaptured ? detail.Summary.DateOfBirth.Month : 1;
            return;
        }

        errorMsg = result.Error;
    }

    private static string FormatNumber(int value) => value.ToString("N0");
    private static string FormatNullableNumber(int? value) => value.HasValue ? value.Value.ToString("N0") : "No disponible";
    private static string FormatDate(DateTime value) => value.ToLocalTime().ToString("dd MMM yyyy");
    private static string FormatDateTime(DateTime value) => value.ToLocalTime().ToString("dd MMM yyyy HH:mm");
    private static string FormatNullableDate(DateTime? value) => value.HasValue ? FormatDate(value.Value) : "No disponible";
    private static string FormatNullableDateTime(DateTime? value) => value.HasValue ? FormatDateTime(value.Value) : "No disponible";
    private static string DisplayText(string? value) => string.IsNullOrWhiteSpace(value) ? "No disponible" : value;
    private static string CampaignText(string? campaignName, decimal? appliedMultiplier) =>
        string.IsNullOrWhiteSpace(campaignName)
            ? "No disponible"
            : appliedMultiplier.HasValue
                ? $"{campaignName} ({appliedMultiplier.Value:0.##}x)"
                : campaignName;
    private static string PointColor(int points) => points >= 0 ? "var(--kb-sage)" : "var(--kb-blush)";
    private static string StatusText(bool isActive) => isActive ? "Activo" : "Inactivo";
    private static string YesNo(bool value) => value ? "Si" : "No";
    private string BirthdayText() =>
        detail?.Summary.BirthdayCaptured == true
            ? $"{detail.Summary.DateOfBirth.Day} de {MonthName(detail.Summary.DateOfBirth.Month)}"
            : "No capturado";

    private async Task SaveBirthdayAsync()
    {
        if (detail is null)
            return;

        birthdayError = null;
        birthdaySuccess = null;
        if (birthdayDay < 1 || birthdayMonth < 1 || birthdayMonth > 12 || birthdayDay > DateTime.DaysInMonth(2000, birthdayMonth))
        {
            birthdayError = "El día no es válido para el mes seleccionado.";
            return;
        }

        birthdayBusy = true;
        try
        {
            var result = await Sender.Send(new UpdateCustomerBirthdayCommand(
                detail.Summary.CustomerId,
                SerialNumber: null,
                birthdayDay,
                birthdayMonth));

            if (result.IsFailure)
            {
                birthdayError = result.Error;
                return;
            }

            birthdaySuccess = "Cumpleaños guardado.";
            var refreshed = await Sender.Send(new GetCustomerDetailQuery(detail.Summary.CustomerId));
            if (refreshed.IsSuccess)
                detail = refreshed.Value;
        }
        finally
        {
            birthdayBusy = false;
        }
    }

    private static string MonthName(int month) => month switch
    {
        1 => "Enero",
        2 => "Febrero",
        3 => "Marzo",
        4 => "Abril",
        5 => "Mayo",
        6 => "Junio",
        7 => "Julio",
        8 => "Agosto",
        9 => "Septiembre",
        10 => "Octubre",
        11 => "Noviembre",
        12 => "Diciembre",
        _ => month.ToString()
    };

    private static string ThresholdText(int threshold, int rollingPoints) =>
        rollingPoints >= threshold ? $"{threshold:N0} ✓" : threshold.ToString("N0");

    private static string StatusBadgeClass(bool isActive) =>
        isActive ? "kb-badge kb-badge--success" : "kb-badge kb-badge--muted";

    private static string RedemptionStatusBadgeClass(RedemptionStatus status) => status switch
    {
        RedemptionStatus.Pending => "kb-badge kb-badge--warning",
        RedemptionStatus.Confirmed => "kb-badge kb-badge--success",
        RedemptionStatus.Cancelled => "kb-badge kb-badge--muted",
        _ => "kb-badge"
    };

    private static string LotStatusBadgeClass(string status) => status switch
    {
        "Activo" => "kb-badge kb-badge--success",
        "Parcialmente consumido" => "kb-badge kb-badge--warning",
        "Consumido" => "kb-badge kb-badge--muted",
        "Expirado" => "kb-badge kb-badge--muted",
        _ => "kb-badge"
    };

    private static string NotificationStatusBadgeClass(NotificationStatus status) => status switch
    {
        NotificationStatus.Delivered => "kb-badge kb-badge--success",
        NotificationStatus.PartiallyDelivered => "kb-badge kb-badge--warning",
        NotificationStatus.Failed => "kb-badge kb-badge--warning",
        NotificationStatus.Cancelled => "kb-badge kb-badge--muted",
        _ => "kb-badge kb-badge--muted"
    };
}
