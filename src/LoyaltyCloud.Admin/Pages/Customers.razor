@page "/customers"
@attribute [Authorize]
@rendermode InteractiveServer

@using LoyaltyCloud.Application.Customers.Queries.GetCustomers
@using LoyaltyCloud.Common.Results
@inject ISender Sender

<PageTitle>Clientas · LoyaltyCloud</PageTitle>

<h1>Clientas</h1>

<div class="kb-form-row kb-form-row--horizontal">
    <div style="flex: 2; min-width: 240px;">
        <label for="search">Buscar (nombre, email o serial)</label>
        <input id="search" type="text" @bind="searchTerm" @bind:event="oninput"
               @onkeydown="@(e => { if (e.Key == "Enter") ReloadAsync(); })" />
    </div>
    <div style="flex: 1; min-width: 160px;">
        <label for="level">Nivel</label>
        <select id="level" @bind="levelFilter" @bind:after="ReloadAsync">
            <option value="">Todos</option>
            <option value="@LoyaltyConstants.Levels.Mist">Mist</option>
            <option value="@LoyaltyConstants.Levels.Glow">Glow</option>
            <option value="@LoyaltyConstants.Levels.Radiance">Radiance</option>
        </select>
    </div>
    <button class="kb-btn kb-btn--primary" @onclick="ReloadAsync">Filtrar</button>
</div>

@if (page is null)
{
    <p>Cargando…</p>
}
else if (page.Items.Count == 0)
{
    <p style="color: var(--kb-ink-muted);">Sin resultados.</p>
}
else
{
    <table class="kb-table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Email</th>
                <th>Serial</th>
                <th>Nivel</th>
                <th>Puntos</th>
                <th>Alta</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in page.Items)
        {
            <tr>
                <td>@c.FullName</td>
                <td style="color: var(--kb-ink-muted);">@c.Email</td>
                <td><code>@c.SerialNumber</code></td>
                <td><LevelBadge Level="@c.Level" /></td>
                <td style="font-weight: 600;">@c.CurrentPoints.ToString("N0")</td>
                <td style="color: var(--kb-ink-muted);">@c.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                <td><a href="/customers/@c.CustomerId">Ver detalle</a></td>
            </tr>
        }
        </tbody>
    </table>

    <div class="kb-form-row kb-form-row--horizontal" style="margin-top: 20px;">
        <button class="kb-btn kb-btn--ghost" @onclick="PrevPage" disabled="@(!page.HasPrevious)">← Anterior</button>
        <span style="color: var(--kb-ink-muted);">
            Página @(page.PageNumber) de @(page.TotalPages) (@(page.TotalCount) clientas)
        </span>
        <button class="kb-btn kb-btn--ghost" @onclick="NextPage" disabled="@(!page.HasNext)">Siguiente →</button>
    </div>
}

@code {
    private string searchTerm = string.Empty;
    private string levelFilter = string.Empty;
    private int pageNumber = 1;
    private PagedResult<CustomerListItemDto>? page;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        var pagination = new PaginationParams { PageNumber = pageNumber, PageSize = 20 };
        var result = await Sender.Send(new GetCustomersQuery(
            string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
            string.IsNullOrWhiteSpace(levelFilter) ? null : levelFilter,
            pagination));
        if (result.IsSuccess) page = result.Value;
    }

    private async Task PrevPage() { pageNumber = Math.Max(1, pageNumber - 1); await ReloadAsync(); }
    private async Task NextPage() { pageNumber++; await ReloadAsync(); }
}
