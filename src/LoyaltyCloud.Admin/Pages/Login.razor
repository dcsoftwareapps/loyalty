@page "/{TenantSlug}/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using LoyaltyCloud.Admin.Auth
@using LoyaltyCloud.Application.Common.Interfaces
@inject AdminAuthService Auth
@inject IPublicTenantResolver TenantResolver

@*
  Renderizada como Static SSR (sin @rendermode). Necesario porque la firma
  de la cookie con HttpContext.SignInAsync solo puede ocurrir antes de que
  empiece a fluir la response al cliente.
*@

<div class="kb-login" style="@TenantStyle">
    <div class="kb-login-card">
        <div class="kb-login-brand">
            @if (!string.IsNullOrWhiteSpace(tenant?.LogoUrl))
            {
                <img src="@tenant.LogoUrl" alt="@tenant.DisplayName" class="kb-brand-logo" />
            }
            else
            {
                <h1>@(tenant?.DisplayName ?? "LoyaltyCloud")</h1>
            }
            <p class="kb-muted">Acceso administrativo</p>
        </div>

        @if (error is not null)
        {
            <div class="kb-form-error">@error</div>
        }

        <form method="post" @formname="login" @onsubmit="HandleSubmit" @onsubmit:preventDefault="false">
            <AntiforgeryToken />
            <div class="kb-form-row">
                <div>
                    <label for="username">Usuario</label>
                    <input id="username" name="Input.Username" type="text" autocomplete="username" required />
                </div>
                <div>
                    <label for="password">Contraseña</label>
                    <input id="password" name="Input.Password" type="password" autocomplete="current-password" required />
                </div>
                <button type="submit" class="kb-btn kb-btn--primary kb-btn--block kb-btn--large">
                    Entrar
                </button>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(TenantSlug))
        {
            <p class="kb-muted" style="margin-top: 16px;">Programa: @(tenant?.DisplayName ?? TenantSlug)</p>
        }
    </div>
</div>

@code {
    [CascadingParameter] public HttpContext HttpContext { get; set; } = default!;
    [Parameter] public string? TenantSlug { get; set; }
    [SupplyParameterFromForm] public LoginInput Input { get; set; } = new();
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private PublicTenantInfo? tenant;
    private string? error;
    private string TenantStyle =>
        tenant is null
            ? string.Empty
            : $"--kb-blush:{tenant.PrimaryColor};--kb-sand-100:{tenant.SecondaryColor};";

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(TenantSlug))
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            error = "Programa no encontrado.";
            return;
        }

        tenant = await TenantResolver.ResolveBySlugAsync(TenantSlug);
        if (tenant is null)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            error = "Programa no encontrado.";
            return;
        }

        if (!tenant.IsOperational)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status403Forbidden;
            error = "Este programa está suspendido temporalmente.";
            return;
        }

        if (HttpMethods.IsGet(HttpContext.Request.Method) &&
            HttpContext.User.Identity?.IsAuthenticated == true)
        {
            HttpContext.Response.Redirect("/dashboard");
            return;
        }

        if (HttpMethods.IsPost(HttpContext.Request.Method))
        {
            var result = await Auth.TrySignInAsync(HttpContext, TenantSlug, Input.Username, Input.Password);
            if (result == AdminLoginResult.Success)
            {
                var dest = IsLocalReturnUrl(ReturnUrl) ? ReturnUrl! : "/dashboard";
                HttpContext.Response.Redirect(dest);
            }
            else
            {
                error = result switch
                {
                    AdminLoginResult.TenantNotFound => "Programa no encontrado.",
                    AdminLoginResult.TenantUnavailable => "Este programa está suspendido temporalmente.",
                    _ => "Usuario o contraseña incorrectos."
                };
            }
        }
    }

    private void HandleSubmit() { /* el procesamiento ocurre en OnInitializedAsync tras el postback */ }

    private static bool IsLocalReturnUrl(string? value) =>
        !string.IsNullOrWhiteSpace(value)
        && value.StartsWith('/')
        && !value.StartsWith("//");

    public sealed class LoginInput
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
