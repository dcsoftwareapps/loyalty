@page "/"
@page "/dashboard"
@attribute [Authorize]
@rendermode InteractiveServer

@using LoyaltyCloud.Application.Admin.Queries.GetDashboardSummary
@inject ISender Sender

<PageTitle>Dashboard - LoyaltyCloud</PageTitle>

<h1>Dashboard</h1>
<p style="color: var(--kb-ink-muted); margin-top: -8px; max-width: 720px;">
    Resumen operativo del programa de lealtad con datos reales del sistema.
</p>

@if (errorMsg is not null)
{
    <div class="kb-form-error">@errorMsg</div>
}

@if (dashboard is null && errorMsg is null)
{
    <p>Cargando...</p>
}
else if (dashboard is not null)
{
    <section style="margin-bottom:32px;">
        <h2>Clientes</h2>
        <div class="kb-grid">
            <MetricCard Label="Total registrados" Value="@FormatNumber(dashboard.Customers.TotalCustomers)" />
            <MetricCard Label="Nuevos este mes" Value="@FormatNumber(dashboard.Customers.NewCustomersThisMonth)" />
            <MetricCard Label="Wallet emitida" Value="@FormatNumber(dashboard.Customers.CustomersWithWallet)" />
            <MetricCard Label="Activos" Value="@FormatNumber(dashboard.Customers.ActiveCustomers)" />
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Puntos</h2>
        <div class="kb-grid">
            <MetricCard Label="Puntos otorgados" Value="@FormatNumber(dashboard.Points.PointsIssued)" />
            <MetricCard Label="Puntos canjeados" Value="@FormatNumber(dashboard.Points.PointsRedeemed)" />
            <MetricCard Label="Puntos expirados" Value="@FormatNumber(dashboard.Points.PointsExpired)" />
            <MetricCard Label="Balance total actual" Value="@FormatNumber(dashboard.Points.CurrentPointBalance)" />
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Canjes</h2>
        <div class="kb-grid">
            <MetricCard Label="Pendientes" Value="@FormatNumber(dashboard.Redemptions.Pending)" />
            <MetricCard Label="Confirmados" Value="@FormatNumber(dashboard.Redemptions.Confirmed)" />
            <MetricCard Label="Cancelados" Value="@FormatNumber(dashboard.Redemptions.Cancelled)" />
            <MetricCard Label="Total" Value="@FormatNumber(dashboard.Redemptions.Total)" />
        </div>
    </section>

    <section style="margin-bottom:32px;">
        <h2>Recompensas</h2>
        <div class="kb-grid">
            <MetricCard Label="Total" Value="@FormatNumber(dashboard.Rewards.Total)" />
            <MetricCard Label="Activas" Value="@FormatNumber(dashboard.Rewards.Active)" />
            <MetricCard Label="Inactivas" Value="@FormatNumber(dashboard.Rewards.Inactive)" />
        </div>
    </section>

    <section>
        <h2>Actividad reciente</h2>
        @if (dashboard.RecentActivity.Count == 0)
        {
            <p style="color: var(--kb-ink-muted);">Aun no hay actividad registrada.</p>
        }
        else
        {
            <table class="kb-table kb-table--compact">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Detalle</th>
                        <th>Cliente</th>
                        <th>Serial</th>
                        <th class="kb-cell-number">Puntos</th>
                        <th>Estado</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in dashboard.RecentActivity)
                {
                    <tr>
                        <td><span class="kb-badge kb-badge--muted">@item.Type</span></td>
                        <td>@item.Description</td>
                        <td>@item.CustomerName</td>
                        <td><code>@item.SerialNumber</code></td>
                        <td class="kb-cell-number" style="font-weight:600;color:@PointColor(item.Points);">
                            @(item.Points > 0 ? "+" : "")@item.Points.ToString("N0")
                        </td>
                        <td class="kb-muted">@DisplayText(item.Status)</td>
                        <td class="kb-muted">@item.OccurredAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private DashboardSummaryDto? dashboard;
    private string? errorMsg;

    protected override async Task OnInitializedAsync()
    {
        var result = await Sender.Send(new GetDashboardSummaryQuery());
        if (result.IsSuccess)
        {
            dashboard = result.Value;
            return;
        }

        errorMsg = result.Error;
    }

    private static string PointColor(int points) =>
        points >= 0 ? "var(--kb-sage)" : "var(--kb-blush)";

    private static string FormatNumber(int value) => value.ToString("N0");

    private static string DisplayText(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;
}
