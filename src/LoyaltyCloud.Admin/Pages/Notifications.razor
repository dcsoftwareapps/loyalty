@page "/notifications"
@attribute [Authorize]
@rendermode InteractiveServer

@using LoyaltyCloud.Application.Notifications
@using LoyaltyCloud.Application.Notifications.Commands.CancelNotification
@using LoyaltyCloud.Application.Notifications.Commands.ProcessNotification
@using LoyaltyCloud.Application.Notifications.Commands.RetryNotification
@using LoyaltyCloud.Application.Notifications.Queries.GetNotificationMetrics
@using LoyaltyCloud.Application.Notifications.Queries.ListNotifications
@using LoyaltyCloud.Domain.Enums
@inject ISender Sender

<PageTitle>Notificaciones - LoyaltyCloud</PageTitle>

<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:24px;">
    <div>
        <h1>Notificaciones</h1>
        <p class="kb-muted" style="margin-top:-8px;">
            Mensajes lógicos de lealtad y entregas por Apple Wallet.
        </p>
    </div>
</div>

@if (successMsg is not null) { <div class="kb-form-success">@successMsg</div> }
@if (errorMsg is not null) { <div class="kb-form-error">@errorMsg</div> }

@if (metrics is not null)
{
    <section style="margin-bottom:32px;">
        <div class="kb-grid">
            <MetricCard Label="Pendientes" Value="@metrics.Pending.ToString("N0")" />
            <MetricCard Label="Procesadas" Value="@metrics.Processed.ToString("N0")" />
            <MetricCard Label="Fallidas" Value="@metrics.Failed.ToString("N0")" />
            <MetricCard Label="Clientas alcanzadas" Value="@metrics.CustomersReached.ToString("N0")" />
            <MetricCard Label="Pushes intentados" Value="@metrics.PushesAttempted.ToString("N0")" />
            <MetricCard Label="Pushes fallidos" Value="@metrics.PushesFailed.ToString("N0")" />
        </div>
    </section>
}

<div class="kb-form-row kb-form-row--horizontal" style="margin-bottom:20px;">
    <div style="flex:1;min-width:180px;">
        <label for="status-filter">Estado</label>
        <select id="status-filter" @bind="statusFilter">
            <option value="">Todos</option>
            <option value="@NotificationStatus.Pending">Pending</option>
            <option value="@NotificationStatus.Processing">Processing</option>
            <option value="@NotificationStatus.Delivered">Delivered</option>
            <option value="@NotificationStatus.PartiallyDelivered">PartiallyDelivered</option>
            <option value="@NotificationStatus.Failed">Failed</option>
            <option value="@NotificationStatus.Cancelled">Cancelled</option>
        </select>
    </div>
    <div style="flex:1;min-width:180px;">
        <label for="type-filter">Tipo</label>
        <select id="type-filter" @bind="typeFilter">
            <option value="">Todos</option>
            <option value="@NotificationType.LevelChanged">LevelChanged</option>
            <option value="@NotificationType.PointsExpiring">PointsExpiring</option>
            <option value="@NotificationType.MonthlyProductStarted">MonthlyProductStarted</option>
            <option value="@NotificationType.PointCampaignStarted">PointCampaignStarted</option>
            <option value="@NotificationType.BirthdayBenefitStarted">BirthdayBenefitStarted</option>
            <option value="@NotificationType.Custom">Custom</option>
        </select>
    </div>
    <div class="kb-actions-inline" style="align-self:end;">
        <button class="kb-btn kb-btn--ghost" @onclick="LoadAsync" disabled="@busy">Aplicar</button>
    </div>
</div>

@if (notifications is null)
{
    <p>Cargando...</p>
}
else if (notifications.Count == 0)
{
    <p class="kb-muted">No hay notificaciones para este filtro.</p>
}
else
{
    <table class="kb-table kb-table--compact">
        <thead>
            <tr>
                <th>Creada</th>
                <th>Cliente</th>
                <th>Serial</th>
                <th>Tipo</th>
                <th>Mensaje</th>
                <th>Estado</th>
                <th>Apple Wallet</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in notifications)
        {
            var wallet = item.Deliveries.FirstOrDefault(d => d.Channel == NotificationChannel.AppleWallet);
            <tr>
                <td class="kb-muted">@FormatDateTime(item.CreatedAt)</td>
                <td>@DisplayText(item.CustomerName)</td>
                <td class="kb-muted">@DisplayText(item.SerialNumber)</td>
                <td><span class="kb-badge kb-badge--muted">@item.Type</span></td>
                <td>
                    <strong>@item.Title</strong>
                    <div class="kb-muted kb-text-truncate" title="@item.Message">@item.Message</div>
                </td>
                <td><span class="@NotificationStatusClass(item.Status)">@item.Status</span></td>
                <td>
                    @if (wallet is null)
                    {
                        <span class="kb-muted">No disponible</span>
                    }
                    else
                    {
                        <span class="@DeliveryStatusClass(wallet.Status)">@wallet.Status</span>
                        <div class="kb-muted" title="@wallet.FailureReason">
                            @wallet.PushesAccepted/@wallet.PushesAttempted aceptados
                        </div>
                    }
                </td>
                <td>
                    <div class="kb-actions-inline">
                        @if (item.Status == NotificationStatus.Pending)
                        {
                            <button class="kb-btn kb-btn--primary kb-btn--small" @onclick="@(() => ProcessAsync(item.Id))" disabled="@busy">Procesar</button>
                            <button class="kb-btn kb-btn--ghost kb-btn--small" @onclick="@(() => CancelAsync(item.Id))" disabled="@busy">Cancelar</button>
                        }
                        else if (item.Status == NotificationStatus.Failed)
                        {
                            <button class="kb-btn kb-btn--primary kb-btn--small" @onclick="@(() => RetryAsync(item.Id))" disabled="@busy">Reintentar</button>
                        }
                        else
                        {
                            <span class="kb-muted">Sin acciones</span>
                        }
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private List<NotificationDto>? notifications;
    private NotificationMetricsDto? metrics;
    private string? statusFilter;
    private string? typeFilter;
    private string? successMsg;
    private string? errorMsg;
    private bool busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        busy = true;
        errorMsg = null;
        try
        {
            var status = Enum.TryParse<NotificationStatus>(statusFilter, out var parsedStatus) ? parsedStatus : (NotificationStatus?)null;
            var type = Enum.TryParse<NotificationType>(typeFilter, out var parsedType) ? parsedType : (NotificationType?)null;

            var listResult = await Sender.Send(new ListNotificationsQuery(Status: status, Type: type, Take: 100));
            var metricsResult = await Sender.Send(new GetNotificationMetricsQuery());

            if (listResult.IsFailure)
            {
                errorMsg = listResult.Error;
                notifications = new List<NotificationDto>();
            }
            else
            {
                notifications = listResult.Value.ToList();
            }

            if (metricsResult.IsSuccess)
                metrics = metricsResult.Value;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ProcessAsync(Guid id) => await ExecuteAsync(() => Sender.Send(new ProcessNotificationCommand(id)), "Notificación procesada.");
    private async Task RetryAsync(Guid id) => await ExecuteAsync(() => Sender.Send(new RetryNotificationCommand(id)), "Notificación reintentada.");
    private async Task CancelAsync(Guid id) => await ExecuteAsync(() => Sender.Send(new CancelNotificationCommand(id)), "Notificación cancelada.");

    private async Task ExecuteAsync(Func<Task<LoyaltyCloud.Common.Results.Result<NotificationDto>>> operation, string success)
    {
        busy = true;
        successMsg = null;
        errorMsg = null;
        try
        {
            var result = await operation();
            if (result.IsFailure)
            {
                errorMsg = result.Error;
                return;
            }

            successMsg = success;
            await LoadAsync();
        }
        finally
        {
            busy = false;
        }
    }

    private static string FormatDateTime(DateTime value) => value.ToLocalTime().ToString("dd MMM yyyy HH:mm");
    private static string DisplayText(string? value) => string.IsNullOrWhiteSpace(value) ? "No disponible" : value;

    private static string NotificationStatusClass(NotificationStatus status) => status switch
    {
        NotificationStatus.Delivered => "kb-badge kb-badge--success",
        NotificationStatus.PartiallyDelivered => "kb-badge kb-badge--warning",
        NotificationStatus.Failed => "kb-badge kb-badge--warning",
        NotificationStatus.Cancelled => "kb-badge kb-badge--muted",
        _ => "kb-badge kb-badge--muted"
    };

    private static string DeliveryStatusClass(NotificationDeliveryStatus status) => status switch
    {
        NotificationDeliveryStatus.Succeeded => "kb-badge kb-badge--success",
        NotificationDeliveryStatus.Failed => "kb-badge kb-badge--warning",
        NotificationDeliveryStatus.NoRecipients => "kb-badge kb-badge--muted",
        NotificationDeliveryStatus.Unsupported => "kb-badge kb-badge--muted",
        _ => "kb-badge kb-badge--muted"
    };

}
