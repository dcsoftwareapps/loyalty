@inject NavigationManager Nav
@using LoyaltyCloud.Admin.Auth

@*
  Helper invocado desde Routes.razor cuando AuthorizeRouteView determina que
  no hay sesión. Hace force-load para que la cookie de antiforgery y el ciclo
  de redirect funcionen correctamente.
*@

@code {
    protected override void OnInitialized()
    {
        var returnUrl = Uri.EscapeDataString(new Uri(Nav.Uri).PathAndQuery);
        var path = new Uri(Nav.Uri).AbsolutePath;
        var loginPath = AdminLoginRedirects.ResolveLoginPath(path);
        Nav.NavigateTo($"{loginPath}?returnUrl={returnUrl}", forceLoad: true);
    }
}
