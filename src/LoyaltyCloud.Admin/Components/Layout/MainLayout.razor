@inherits LayoutComponentBase
@inject LoyaltyCloud.Application.Common.Interfaces.ITenantBrandingReadService Branding

<div class="kb-app" style="@TenantStyle">
    <nav class="kb-sidebar">
        <div class="kb-sidebar-brand">
            @if (!string.IsNullOrWhiteSpace(branding?.LogoUrl))
            {
                <img src="@branding.LogoUrl" alt="@branding.DisplayName" class="kb-brand-logo" />
            }
            else
            {
                <h1>@(branding?.DisplayName ?? "LoyaltyCloud")</h1>
            }
            <span>LoyaltyCloud</span>
        </div>
        <NavLink href="/dashboard" Match="NavLinkMatch.All">Dashboard</NavLink>
        <NavLink href="/scan">Sumar puntos</NavLink>
        <NavLink href="/redeem">Canjear</NavLink>
        <NavLink href="/customers">Clientas</NavLink>
        <NavLink href="/redemptions">Canjes</NavLink>
        <NavLink href="/rewards">Recompensas</NavLink>
        <NavLink href="/campaigns">Campañas</NavLink>
        <NavLink href="/marketing-notifications">Mensajes</NavLink>
        <NavLink href="/config">Configuración</NavLink>

        <form method="post" action="/logout" class="kb-signout">
            <AntiforgeryToken />
            <button type="submit" class="kb-btn kb-btn--ghost" style="width:100%;margin-top:8px;">
                Cerrar sesión
            </button>
        </form>
    </nav>

    <main class="kb-main">
        @Body
    </main>
</div>

@code {
    private LoyaltyCloud.Application.Common.Interfaces.TenantBrandingInfo? branding;

    private string TenantStyle =>
        branding is null
            ? string.Empty
            : $"--kb-blush:{branding.PrimaryColor};--kb-sand-100:{branding.SecondaryColor};";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            branding = await Branding.GetCurrentAsync();
        }
        catch
        {
            branding = null;
        }
    }
}
