        <NavLink href="/dashboard" Match="NavLinkMatch.All">Dashboard</NavLink>
        <NavLink href="/scan">Sumar puntos</NavLink>
        <NavLink href="/customers">Clientas</NavLink>
        <NavLink href="/redemptions">Canjes</NavLink>
